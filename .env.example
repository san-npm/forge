# Secret token for blog POST API (create any random string)
# Used to authenticate blog publishing from AI agents or scripts
BLOG_SECRET=your-secret-token-here

# Secret token for the admin notifications dashboard (/admin/notifications)
ADMIN_TOKEN=your-admin-token-here

# Optional: webhook URL for real-time notifications on new contacts/subscribers
# Works with Slack, Discord, Make.com, Zapier, etc.
# NOTIFICATION_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Optional: Telegram bot for instant lead notifications (recommended)
# Create a bot via @BotFather and grab your chat id from @userinfobot
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=735726338

# Optional: override IndexNow key (defaults to the file in /public)
# INDEXNOW_KEY=bdc7fbebeb30295aa4a9f9dc3ba9b80f
# INDEXNOW_HOST=www.openletz.com
